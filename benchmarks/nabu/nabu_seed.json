{
  "meta": {
    "name": "bench_nabu",
    "about": "Nabu — Babylonian god of scribes and record-keeping. An agent runs missions to amass VERIFIED facts across three domains that triangulate human physical experience: the body (emergency medicine), matter (chemistry), and culture (anthropology). Every fact is checkable against an authoritative snapshot, so the benchmark never grades an LLM with an LLM.",
    "honesty": {
      "chem": "Values are PubChem authority (public domain). molecular_formula and molecular_weight are strictly checked; cid is recall-only (verified on --refresh).",
      "med": "Drug class / indication / route reflect standard emergency-medicine practice and US-approved labeling (openFDA). This is the medical record, not universal or individualized medical truth.",
      "anthro": "Values are the ethnographic record (D-PLACE / Ethnographic Atlas lineage), which carries known Murdock-era sampling and coding biases. This scores recall of that record, NOT truth about living cultures."
    },
    "bridges": "med:<drug>.active_moiety = <compound> (a chem entity id), and <compound>.molecular_formula = <formula>. compose() therefore derives med -> formula, a body<->matter fact no single source wrote. These derivations are the cross-domain yield metric."
  },
  "entities": {
